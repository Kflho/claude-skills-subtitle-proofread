{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Report — authoritative fix-status store",
  "description": "temp/report.json: JSON-encoded fix status for all pipeline layers.",
  "type": "object",
  "required": ["version", "layers"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version (currently 1)."
    },
    "updated": {
      "type": "string",
      "description": "ISO 8601 timestamp of last write."
    },
    "layers": {
      "type": "object",
      "description": "Layer ID → list of entries.",
      "properties": {
        "2":   { "type": "array", "items": { "$ref": "#/definitions/reportEntry" } },
        "2.5": { "type": "array", "items": { "$ref": "#/definitions/reportEntry" } },
        "3":   { "type": "array", "items": { "$ref": "#/definitions/reportEntry" } },
        "3.5": { "type": "array", "items": { "$ref": "#/definitions/reportEntry" } },
        "4":   { "type": "array", "items": { "$ref": "#/definitions/reportEntry" } },
        "6":   { "type": "array", "items": { "$ref": "#/definitions/reportEntry" } }
      }
    }
  },
  "definitions": {
    "reportEntry": {
      "type": "object",
      "required": ["ep", "time", "original", "status"],
      "properties": {
        "ep":        { "type": "string" },
        "time":      { "type": "string" },
        "original":  { "type": "string" },
        "corrected": { "type": "string" },
        "status":    { "type": "string", "enum": ["✅", "⬜", "🗑️"] }
      }
    }
  }
}
